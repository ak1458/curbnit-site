# ─────────────────────────────────────────────────────────────
# Curb'n IT — environment config
# Copy this file to ".env.local" and fill in real values.
# Everything here is OPTIONAL — the site builds and runs without it
# (chat falls back to FAQ-only, form mocks success in dev).
# ─────────────────────────────────────────────────────────────

# --- Business contact (overrides defaults in lib/config.ts) ---
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_VENMO=
NEXT_PUBLIC_EMAIL=

# --- AI assistant -------------------------------------------------
# Provider: "grok" or "openrouter". Leave key blank to run FAQ-only.
NEXT_PUBLIC_AI_PROVIDER=grok

# Grok (xAI) — https://console.x.ai/
NEXT_PUBLIC_GROK_ENDPOINT=https://api.x.ai/v1/chat/completions
NEXT_PUBLIC_GROK_MODEL=grok-2-latest
NEXT_PUBLIC_GROK_API_KEY=

# OpenRouter — https://openrouter.ai/keys
NEXT_PUBLIC_OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
NEXT_PUBLIC_OPENROUTER_MODEL=x-ai/grok-2-1212
NEXT_PUBLIC_OPENROUTER_API_KEY=
# SECURITY: a NEXT_PUBLIC_ key ships in the browser bundle. Use a
# usage-capped / spend-limited key. To hide it fully later, set the
# form/chat to proxy mode and move the key into public/config.php.

# --- Contact form -------------------------------------------------
# Form mode: "web3forms" (no backend, default), "php" (submit.php → Titan SMTP), or "formspree".
NEXT_PUBLIC_FORM_MODE=web3forms
# Web3Forms key is PUBLIC by design. Default key is baked into lib/config.ts;
# override here to point leads at a different Web3Forms inbox.
NEXT_PUBLIC_WEB3FORMS_KEY=e920bd9a-dc5c-4cd5-9df6-0eae5091845f
NEXT_PUBLIC_FORM_PHP_ENDPOINT=/submit.php
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
